# Since the ".env" file is gitignored, you can use the ".env.example" file to
# build a new ".env" file when you clone the repo. Keep this file up-to-date
# when you add new variables to `.env`.
#
# This file is committed to version control — use placeholders only, no secrets.
# Copy to ".env" and fill in real values:
#   cp .env.example .env

# When adding client-side variables, prefix them with VITE_ so Vite exposes them
# in the browser build.

# -----------------------------------------------------------------------------
# Required — database
# -----------------------------------------------------------------------------
# Local Postgres (host): use the port your DB listens on (docker-compose maps 5434:5432).
# Inside Docker Compose, DATABASE_URL is overridden to postgresql://postgres:postgres@db:5432/vestibulon2
DATABASE_URL="postgresql://postgres:postgres@localhost:5434/vestibulon2"

# -----------------------------------------------------------------------------
# Required — WorkOS auth (login, sessions, /api/* that use auth)
# From https://dashboard.workos.com — API Keys + your AuthKit / SSO application
# WORKOS_COOKIE_PASSWORD must be a long random string (32+ chars); generate once and keep stable.
WORKOS_CLIENT_ID="client_xxxxxxxxxxxxxxxxxxxxxxxx"
WORKOS_API_KEY="sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
WORKOS_COOKIE_PASSWORD="replace-with-a-long-random-secret-at-least-32-chars"

# -----------------------------------------------------------------------------
# Optional — server
# -----------------------------------------------------------------------------
# Session cookie name (default: vestibulon_session)
APP_SESSION_COOKIE_NAME="vestibulon_session"

# Comma-separated extra origins for credentialed cross-origin API requests.
# Same-origin is always allowed; capacitor://localhost is allowed by default for the native webview.
# Leave empty for local-only web dev.
APP_ALLOWED_ORIGINS=""

# -----------------------------------------------------------------------------
# Optional — client (Capacitor / native builds only)
# -----------------------------------------------------------------------------
# Not needed for `npm run dev` in the browser (same-origin /api). Required on iOS/Android
# so fetch() can reach your deployed API (https origin, e.g. your Vercel app URL).
# VITE_API_BASE_URL="https://your-app.vercel.app"
